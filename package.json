    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "driver.js": "^1.4.0",
    "react": "^19.0.0",
    "react-data-grid": "^7.0.0-beta.59",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
