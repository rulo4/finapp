{
  "name": "auna",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:remote": "vite --mode remote",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "repo:doctor": "node tooling/repo-doctor.mjs",
    "repo:doctor:json": "node tooling/repo-doctor.mjs --json",
    "migration:new": "node tooling/migration-new.mjs",
    "migration:review": "node tooling/migration-review.mjs",
    "seed:catalogs:staging-demo": "node tooling/seed-catalogs.mjs --env-file .env.remote --preset staging-demo",
    "mcp:supabase:readonly": "node tools/mcp/supabase-readonly/server.mjs",
    "sync:supabase:db": "node scripts/sync-supabase-public-auth-storage.mjs",
    "supabase:start": "pnpm --config.ignore-scripts=false dlx supabase start",
    "supabase:status": "pnpm --config.ignore-scripts=false dlx supabase status",
    "supabase:stop": "pnpm --config.ignore-scripts=false dlx supabase stop",
    "supabase:reset": "pnpm --config.ignore-scripts=false dlx supabase db reset"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@supabase/supabase-js": "^2.49.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "driver.js": "^1.4.0",
    "react": "^19.0.0",
    "react-data-grid": "^7.0.0-beta.59",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "pg": "^8.16.3",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "zod": "^3.25.76"
  }
}
