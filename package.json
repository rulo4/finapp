    "supabase:reset": "pnpm --config.ignore-scripts=false dlx supabase db reset"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
